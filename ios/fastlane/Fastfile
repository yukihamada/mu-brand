default_platform(:ios)

XCODEPROJ  = "MU.xcodeproj"
SCHEME     = "MU"
BUNDLE_ID  = "com.wearmu.mu"
WIDGET_ID  = "com.wearmu.mu.widget"
TEAM_ID    = "5BV85JW8US"
OUTPUT_DIR = "build"
KEY_ID     = "5KT46G9Y29"
ISSUER_ID  = "e0d22675-afb3-45f0-a821-06b477f44da0"
KEY_PATH   = File.expand_path("~/.appstoreconnect/private_keys/AuthKey_5KT46G9Y29.p8")

platform :ios do
  private_lane :api_key do
    app_store_connect_api_key(key_id: KEY_ID, issuer_id: ISSUER_ID, key_filepath: KEY_PATH, in_house: false)
  end

  private_lane :generate_project do
    Dir.chdir("..") { sh("xcodegen", "generate") }
  end

  # 自動署名 + APIキーで Archive 時に App Store プロビジョニングを自動作成。
  private_lane :archive_ipa do |options|
    auth = "-allowProvisioningUpdates -authenticationKeyID #{KEY_ID} -authenticationKeyIssuerID #{ISSUER_ID} -authenticationKeyPath #{KEY_PATH}"
    build_app(
      project: XCODEPROJ,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: OUTPUT_DIR,
      output_name: "MU.ipa",
      destination: "generic/platform=iOS",
      derived_data_path: "build_archive",
      export_team_id: TEAM_ID,
      export_options: { signingStyle: "automatic", teamID: TEAM_ID },
      xcargs: auth
    )
  end

  desc "署名済み App Store .ipa を作る"
  lane :build do
    api_key
    generate_project
    archive_ipa
    UI.success("IPA: #{lane_context[SharedValues::IPA_OUTPUT_PATH]}")
  end

  # App Store Connect にアプリレコードを作成(無ければ)。名前は環境変数 MU_APP_NAME で上書き可。
  desc "App Store Connect にアプリ登録"
  lane :make_app do
    api_key  # グローバル token を設定(produce がこれを拾えるか)
    name = ENV["MU_APP_NAME"] || "MU"
    create_app_online(
      app_identifier: BUNDLE_ID,
      app_name: name,
      language: "Japanese",
      sku: "wearmu-mu-001",
      team_id: TEAM_ID,
      itc_team_id: TEAM_ID
    )
    UI.success("アプリ登録 OK: #{name} (#{BUNDLE_ID})")
  end

  desc "ビルド → App Store Connect にアップロード(TestFlight)"
  lane :beta do
    key = api_key
    generate_project
    begin
      latest = latest_testflight_build_number(api_key: key, app_identifier: BUNDLE_ID, initial_build_number: 0)
      increment_build_number(build_number: latest + 1, xcodeproj: XCODEPROJ)
    rescue => e
      UI.important("build番号の取得スキップ: #{e.message}")
    end
    archive_ipa
    upload_to_testflight(
      api_key: key,
      ipa: lane_context[SharedValues::IPA_OUTPUT_PATH],
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
