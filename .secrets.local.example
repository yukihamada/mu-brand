# Copy to .secrets.local (gitignored) and fill in. Used by scripts/mu_drop.py.
# NEVER commit the real .secrets.local.

# Agent API key. Optional — if omitted, mu_drop.py reads the `mu` server key
# from ~/.claude.json. NOTE: the key rotates every time you re-verify by email,
# so if you re-register you must refresh this.
MU_AGENT_KEY=

# Optional. If omitted, mu_drop.py fetches it from the running Fly machine
# via `fly ssh console -a mu-store -C "printenv ..."`.
MU_ADMIN_TOKEN=
PRINTFUL_API_KEY=

# Ship-to address (only needed for --ship). Printful state_code: Tokyo=13.
SHIP_NAME=Your Name
SHIP_ADDR1=2-3-4 Example, #101
SHIP_CITY=Minato-ku
SHIP_STATE=13
SHIP_ZIP=108-0000
SHIP_COUNTRY=JP
