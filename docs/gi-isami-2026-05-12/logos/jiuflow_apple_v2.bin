}
.jf-bottom-nav {
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 99;
  background: rgba(10,10,12,0.95);
  backdrop-filter: blur(12px);
  border-top: 1px solid rgba(255,255,255,0.08);
  display: flex; padding: 0.4rem 0 calc(0.4rem + env(safe-area-inset-bottom));
}
.jf-bottom-nav a {
  flex: 1; display: flex; flex-direction: column; align-items: center; gap: 2px;
  padding: 0.35rem 0.25rem;
  color: rgba(255,255,255,0.45); text-decoration: none; font-size: 0.6rem; font-weight: 500;
  transition: color 0.12s;
}
.jf-bottom-nav a:hover, .jf-bottom-nav a.active { color: #fca5a5; }
.jf-bottom-nav a .icon { font-size: 1.25rem; line-height: 1; }
</style>

