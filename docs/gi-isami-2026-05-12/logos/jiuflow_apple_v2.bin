  <script>
  function showPaywall(title, desc) {
    if(title) document.getElementById('paywall-title').textContent = title;
    if(desc) document.getElementById('paywall-desc').textContent = desc;
    var m = document.getElementById('paywall-modal');
    m.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
  function closePaywall() {
    document.getElementById('paywall-modal').style.display = 'none';
    document.body.style.overflow = '';
  }
  document.getElementById('paywall-modal').addEventListener('click', function(e) {
    if(e.target === this) closePaywall();
  });
  </script>

  <!-- Service Worker registration -->
