  <style>
    body{font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI','Noto Sans JP',Roboto,sans-serif;background:#0A0A0A;color:#fafafa;margin:0;overflow-x:hidden;padding-bottom:calc(env(safe-area-inset-bottom) + 4rem)}
