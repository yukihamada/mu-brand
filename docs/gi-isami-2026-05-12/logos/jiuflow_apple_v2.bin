  </script>

  <!-- SPA Navigation + View Transitions + Prefetch + Active Nav -->
  <script>
  (function(){
    // Active nav state
    function updateActiveNav(){
      document.querySelectorAll('nav a').forEach(function(a){
        try{
          if(a.pathname===location.pathname){a.setAttribute('aria-current','page');}
          else{a.removeAttribute('aria-current');}
        }catch(e){}
      });
    }
    updateActiveNav();

    // NProgress bar helpers
    var _bar=null;
    function npStart(){
      if(_bar){_bar.remove();}
      _bar=document.createElement('div');
      _bar.id='jf-nprogress';
      document.body.prepend(_bar);
      requestAnimationFrame(function(){_bar.style.width='60%';});
    }
    function npDone(){
      if(!_bar)return;
      _bar.classList.add('done');
      var b=_bar;_bar=null;
      setTimeout(function(){b.remove();},450);
    }

    // SPA core
    var SPA={
      cache:new Map(),
      navigate:function(url,push){
        if(push===undefined)push=true;
        npStart();
        var fetchUrl=url+(url.indexOf('?')>=0?'&':'?')+'_pjax=1';
        return fetch(fetchUrl,{headers:{'X-Pjax':'1'},cache:'no-store'})
          .then(function(res){
            if(!res.ok)throw new Error('HTTP '+res.status);
            return res.json();
          })
          .then(function(data){
            if(push)history.pushState({spaPrev:true},data.title,url);
            document.title=data.title;
            var main=document.querySelector('main');
            if(!main)throw new Error('no main');
            if(document.startViewTransition){
              document.startViewTransition(function(){
                main.innerHTML=data.html;
                window.scrollTo(0,0);
                updateActiveNav();
              });
            }else{
              main.innerHTML=data.html;
              window.scrollTo(0,0);
              updateActiveNav();
            }
            npDone();
          })
          .catch(function(){
            npDone();
            if(push)location.href=url;
          });
      }
    };
    window.JF=SPA;

    // SPA pages (PJAX-enabled routes)
    var SPA_PAGES=/^\/(tournaments|athletes|dojos|$|en\/|pt\/)/;

    // Intercept same-origin clicks
    document.addEventListener('click',function(e){
      var a=e.target.closest('a[href]');
      if(!a||a.hostname!==location.hostname||a.target==='_blank'||
         e.metaKey||e.ctrlKey||e.shiftKey||e.altKey||a.download)return;
      var path=a.pathname+(a.search||'');
      if(!SPA_PAGES.test(a.pathname))return; // fall back to full navigation for non-SPA pages
      e.preventDefault();
      SPA.navigate(path);
    });

    // Back/Forward
    window.addEventListener('popstate',function(){
      SPA.navigate(location.pathname+location.search,false);
    });

    // Prefetch on hover (100ms delay, only SPA pages)
    var prefetched=new Set();
    document.addEventListener('mouseover',function(e){
      var a=e.target.closest('a[href]');
      if(!a||a.hostname!==location.hostname||prefetched.has(a.href))return;
      if(!SPA_PAGES.test(a.pathname))return;
      prefetched.add(a.href);
      setTimeout(function(){
        if(!document.querySelector('link[rel="prefetch"][href="'+a.href+'"]')){
          var l=document.createElement('link');l.rel='prefetch';l.href=a.href;
          document.head.appendChild(l);
        }
      },100);
    },{passive:true});
  })();
  </script>

