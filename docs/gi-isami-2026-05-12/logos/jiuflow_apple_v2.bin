    .nav-fixed{position:fixed;top:0;left:0;right:0;z-index:50}
    .hero{position:relative;height:100vh;display:flex;align-items:center;justify-content:center;overflow:hidden}

    /* View Transitions (Task 1) */
    ::view-transition-old(root){animation:150ms cubic-bezier(.4,0,.2,1) both jf-fade-out}
    ::view-transition-new(root){animation:200ms cubic-bezier(.4,0,.2,1) both jf-fade-in}
    @keyframes jf-fade-out{to{opacity:0;transform:translateY(-4px)}}
    @keyframes jf-fade-in{from{opacity:0;transform:translateY(4px)}}

    /* NProgress bar (SPA navigation) */
    #jf-nprogress{position:fixed;top:0;left:0;height:2px;width:0;background:linear-gradient(90deg,#e94560,#ff6b80);z-index:99999;pointer-events:none;transition:width .25s ease,opacity .4s ease}
    #jf-nprogress.done{width:100%;opacity:0}

    /* Skeleton loading (Task 3) */
    .skeleton{background:linear-gradient(90deg,#1a1a1a 25%,#2a2a2a 50%,#1a1a1a 75%);background-size:200% 100%;animation:jf-shimmer 1.4s infinite;border-radius:8px}
    @keyframes jf-shimmer{to{background-position:-200% 0}}
    .skeleton-text{height:1em;margin-bottom:0.5em}
    .skeleton-card{height:120px;margin-bottom:1rem}

    /* Active nav link (Task 7) */
    nav a[aria-current="page"]{color:#fff!important;background:rgba(233,69,96,0.12)!important}

    /* #29: Minimum readable font size for body text on mobile */
    @media (max-width:768px){
      p,li,label,td,th,div{min-height:0}
      input,textarea,select{font-size:16px!important}
    }

    /* #30/#31: Lighter heading weights, secondary accent color */
    h1{font-weight:600}
    h2{font-weight:600}
    h3{font-weight:600}

    /* #43: Focus-visible outline for keyboard nav */
    :focus-visible{outline:2px solid #e94560;outline-offset:3px;border-radius:8px}
    button:focus-visible,a:focus-visible{outline:2px solid #e94560;outline-offset:3px}

    /* #39: Design tokens — border-radius */
    :root{--r-sm:8px;--r-md:12px;--r-pill:9999px}

    /* #40: Button size tokens */
    .btn-primary{display:inline-flex;align-items:center;justify-content:center;min-height:44px;padding:0 1.25rem;border-radius:var(--r-sm);font-weight:600;font-size:0.95rem;cursor:pointer;border:none;text-decoration:none}
    .btn-inline{display:inline-flex;align-items:center;justify-content:center;min-height:32px;padding:0 0.75rem;border-radius:var(--r-sm);font-weight:600;font-size:0.82rem;cursor:pointer;border:none;text-decoration:none}
  </style>

  
