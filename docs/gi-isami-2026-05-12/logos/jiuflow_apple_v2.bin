          <a href="/athletes">選手</a>
          <a href="/news">ニュース</a>
          <a href="/beginners">ガイド</a>
        </div>
      </div>
    </div>

    <div class="jf-divider" style="display:flex;" aria-hidden="true"></div>

    <div class="jf-auth" id="nav-auth-desktop">
      <a href="/login" class="jf-btn-login">ログイン</a>
    </div>

    <!-- Language switcher (desktop) -->
    <div class="jf-lang-switcher desktop-only">
      <button class="jf-lang-btn" title="Language / 言語">
        🌐 JP
        <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="jf-lang-menu">
        <a id="lang-ja-link" href="/" class="active">日本語</a>
        <a id="lang-en-link" href="/en/home" >English</a>
        <a id="lang-pt-link" href="/pt/home" >Português</a>
      </div>
    </div>

    <!-- Hamburger -->
    <button class="jf-hamburger" onclick="document.getElementById('jf-drawer').classList.add('open')" aria-label="メニューを開く">
      <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M3 6h16M3 12h16M3 18h16"/>
      </svg>
    </button>
  </div>
</nav>

<!-- Mobile Drawer -->
<div id="jf-drawer" class="jf-drawer" role="dialog" aria-modal="true" aria-label="メニュー">
  <div class="jf-drawer-overlay" onclick="document.getElementById('jf-drawer').classList.remove('open')"></div>
  <div class="jf-drawer-panel">
    <button class="jf-drawer-close" onclick="document.getElementById('jf-drawer').classList.remove('open')" aria-label="閉じる">
      <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>

    <!-- Mobile language switcher — horizontal pills -->
    <div class="jf-drawer-section">
      <div class="jf-drawer-label">言語</div>
      <div class="jf-drawer-lang-pills">
        <a id="mob-lang-ja-link" href="/" class="jf-lang-pill active">日本語</a>
        <a id="mob-lang-en-link" href="/en/home" class="jf-lang-pill">EN</a>
        <a id="mob-lang-pt-link" href="/pt/home" class="jf-lang-pill">PT</a>
      </div>
    </div>

    <!-- Training: ゲームプラン/ロードマップ/インストラクター only
         (フロー・動画・道場 は bottom tab と重複するため除外 #49) -->
    <div class="jf-drawer-section">
      <div class="jf-drawer-label">トレーニング</div>
      <a href="/game-plans">ゲームプラン</a>
      <a href="/roadmap">ロードマップ</a>
      <a href="/instructors">インストラクター</a>
    </div>

    <!-- Discover: 大会/選手/ニュース/ガイド -->
    <div class="jf-drawer-section">
      <div class="jf-drawer-label">ディスカバー</div>
      <a href="/tournaments">大会</a>
      <a href="/athletes">選手</a>
      <a href="/news">ニュース</a>
      <a href="/beginners">ガイド</a>
