<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
(function(){
  // Highlight active bottom nav item
  var path = window.location.pathname;
  document.querySelectorAll('.jf-bottom-nav a').forEach(function(a){
    if(a.getAttribute('href') === path ||
       (path.startsWith(a.getAttribute('href')) && a.getAttribute('href') !== '/')){
      a.classList.add('active');
    }
  });

  // Hide bottom nav when keyboard opens (input/textarea focused)
  var nav = document.querySelector('.jf-bottom-nav');
  if (!nav) return;
  function hideNav() { nav.style.display = 'none'; }
  function showNav() { nav.style.display = ''; }
  document.addEventListener('focusin', function(e){
    if (e.target && (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT')) {
      hideNav();
    }
  });
  document.addEventListener('focusout', function(e){
    if (e.target && (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT')) {
      setTimeout(showNav, 150);
    }
  });
})();
</script>


  
  

