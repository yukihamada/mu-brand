    <div class="jf-drawer-section" id="nav-auth-mobile">
      <div class="jf-drawer-label">アカウント</div>
      <a href="/login" class="cta">ログイン / 新規登録</a>
    </div>
  </div>
</div>

<!-- Spacer to offset fixed nav height -->
<div style="height:56px;" aria-hidden="true"></div>

<!-- ドメイン変更お知らせバナー -->
<div id="notice-banner" style="background:linear-gradient(90deg,#0a0a1a,#0d0d2a);border-bottom:1px solid rgba(99,102,241,0.4);padding:0.55rem 1rem;display:none;">
  <div style="max-width:900px;margin:0 auto;display:flex;align-items:center;gap:0.7rem;flex-wrap:wrap;">
    <span style="flex-shrink:0;font-size:1rem;">🌐</span>
    <div style="flex:1;min-width:200px;font-size:0.78rem;color:#c7d2fe;line-height:1.6;">
      
      <strong style="color:#a5b4fc;">ドメインが jiuflow.art → jiuflow.com に変わりました。</strong>
      &nbsp;セッションの引き継ぎのため、お手数ですが<a href="/login" style="color:#e94560;font-weight:700;text-decoration:none;">再度ログイン</a>をお願いします。
      
    </div>
    <button onclick="dismissNoticeBanner();" style="flex-shrink:0;background:none;border:none;color:#4b5563;font-size:1.2rem;cursor:pointer;line-height:1;padding:0 0.25rem;">×</button>
  </div>
</div>
<script>
(function(){
  var NOTICE_KEY = 'jf_notice_dismissed_domain_v1';
  function dismissNoticeBanner() {
    document.getElementById('notice-banner').style.display = 'none';
    try { localStorage.setItem(NOTICE_KEY, '1'); } catch(e) {}
  }
  window.dismissNoticeBanner = dismissNoticeBanner;
  try {
    if (!localStorage.getItem(NOTICE_KEY)) {
      document.getElementById('notice-banner').style.display = 'block';
    }
  } catch(e) {
    document.getElementById('notice-banner').style.display = 'block';
  }
})();
</script>

</script>

<script>
(function(){
  // Close drawer on link click
  document.querySelectorAll('#jf-drawer a').forEach(function(a){
    a.addEventListener('click', function(){
      document.getElementById('jf-drawer').classList.remove('open');
    });
  });

  // Close on Escape key
  document.addEventListener('keydown', function(e){
    if(e.key === 'Escape') document.getElementById('jf-drawer').classList.remove('open');
  });

  // Current language for JS
  var currentLang = 'ja' || 'ja';

  // Auth-aware nav update
  fetch('/api/me', {credentials:'include'})
    .then(function(r){ return r.json(); })
    .then(function(data){
      if(!data.logged_in) return;
      var name = data.name || (currentLang === 'en' ? 'My Page' : currentLang === 'pt' ? 'Minha Pagina' : 'マイページ');
      var isOwner = data.role === 'dojo_owner' || data.role === 'admin';

      // Desktop auth area
      var d = document.getElementById('nav-auth-desktop');
      if(d){
        var html = '<a href="/mypage#invite-card" class="jf-link" style="display:flex;align-items:center;gap:0.35rem;background:rgba(233,69,96,0.12);border:1px solid rgba(233,69,96,0.3);border-radius:8px;padding:4px 10px;font-size:0.8rem;font-weight:700;color:#e94560;">🎁 招待</a>'
          + '<a href="/mypage" class="jf-link" style="display:flex;align-items:center;gap:0.35rem;">'
          + '<span style="width:22px;height:22px;border-radius:50%;background:rgba(233,69,96,0.2);border:1px solid rgba(233,69,96,0.35);display:flex;align-items:center;justify-content:center;font-size:0.7rem;">&#x1f464;</span>'
          + '<span style="max-width:80px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:0.82rem;">'+ esc(name) +'</span>'
          + '</a>';
        if(isOwner){
          var adminLabel = currentLang === 'en' ? 'Admin' : currentLang === 'pt' ? 'Admin' : '管理';
          html += '<a href="/dojo-owner/dashboard" class="jf-link" style="color:#a5b4fc;font-size:0.82rem;">'+ adminLabel +'</a>';
        }
        var logoutLabel = currentLang === 'en' ? 'Logout' : currentLang === 'pt' ? 'Sair' : 'ログアウト';
        html += '<form method="POST" action="/logout" style="margin:0;">'
          + '<button type="submit" class="jf-link" style="background:none;border:none;cursor:pointer;color:rgba(255,255,255,0.35);font-size:0.82rem;">'+ logoutLabel +'</button>'
          + '</form>';
        d.innerHTML = html;
      }

      // Mobile auth section
      var m = document.getElementById('nav-auth-mobile');
      if(m){
        var accountLabel = currentLang === 'en' ? 'Account' : currentLang === 'pt' ? 'Conta' : 'アカウント';
        var reservationsLabel = currentLang === 'en' ? 'Reservations' : currentLang === 'pt' ? 'Reservas' : '予約履歴';
        var dojoMgmtLabel = currentLang === 'en' ? 'Dojo Management' : currentLang === 'pt' ? 'Gerenciar Dojo' : '道場管理';
        var attendanceLabel = currentLang === 'en' ? 'Attendance' : currentLang === 'pt' ? 'Presenca' : '出席管理';
        var logoutLabel2 = currentLang === 'en' ? 'Logout' : currentLang === 'pt' ? 'Sair' : 'ログアウト';

        var inviteLabel = currentLang === 'en' ? '🎁 Invite Friends' : currentLang === 'pt' ? '🎁 Convidar Amigos' : '🎁 友達を招待';
        var mhtml = '<div class="jf-drawer-label">'+ accountLabel +'</div>'
          + '<a href="/mypage" style="display:flex;align-items:center;gap:0.5rem;">'
          + '<span style="width:20px;height:20px;border-radius:50%;background:rgba(233,69,96,0.2);border:1px solid rgba(233,69,96,0.35);display:inline-flex;align-items:center;justify-content:center;font-size:0.65rem;flex-shrink:0;">&#x1f464;</span>'
          + '<span style="max-width:190px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' + esc(name) + '</span>'
          + '</a>'
          + '<a href="/mypage#invite-card" style="color:#e94560;font-weight:700;">' + inviteLabel + '</a>'
          + '<a href="/mypage/reservations">&#x1f4c5; ' + reservationsLabel + '</a>';
        if(isOwner){
          mhtml += '<a href="/dojo-owner/dashboard">&#x1f3eb; ' + dojoMgmtLabel + '</a>'
            + '<a href="/dojo-owner/attendance">&#x2705; ' + attendanceLabel + '</a>';
        }
        mhtml += '<form method="POST" action="/logout" style="margin:0;">'
          + '<button type="submit" class="jf-drawer-logout-btn">' + logoutLabel2 + '</button>'
          + '</form>';
        m.innerHTML = mhtml;
      }
    })
    .catch(function(){});

  function esc(s){
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // Dynamic lang switcher: derive sibling-language URL from current path
  // e.g. /en/dojos -> /dojos (ja), /pt/dojos (pt)
  // e.g. /dojos -> /en/dojos (en), /pt/dojos (pt)
  (function(){
    var p = window.location.pathname;
    var jaPath, enPath, ptPath;
    var langPfx = p.match(/^\/(en|pt)(\/|$)/);
    if (langPfx) {
      // strip /en/ or /pt/
      var stripped = p.replace(/^\/(en|pt)/, '') || '/';
      jaPath = stripped;
      enPath = '/en' + (stripped === '/' ? '/home' : stripped);
      ptPath = '/pt' + (stripped === '/' ? '/home' : stripped);
    } else {
      jaPath = p;
      enPath = '/en' + (p === '/' ? '/home' : p);
      ptPath = '/pt' + (p === '/' ? '/home' : p);
    }
    ['lang-ja-link','mob-lang-ja-link'].forEach(function(id){
      var el=document.getElementById(id); if(el) el.href=jaPath;
    });
    ['lang-en-link','mob-lang-en-link'].forEach(function(id){
      var el=document.getElementById(id); if(el) el.href=enPath;
    });
    ['lang-pt-link','mob-lang-pt-link'].forEach(function(id){
      var el=document.getElementById(id); if(el) el.href=ptPath;
    });
  })();
})();
</script>

<main style="padding-top:6rem;padding-bottom:6rem;text-align:center;max-width:600px;margin:0 auto;padding-left:1.5rem;padding-right:1.5rem;">

  <!-- Animated 404 -->
  <div style="position:relative;margin-bottom:2rem;">
    <div style="font-size:clamp(8rem,20vw,12rem);font-weight:900;line-height:1;letter-spacing:-0.06em;background:linear-gradient(135deg,#e94560 0%,#e94560 40%,#3b82f6 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;user-select:none;">404</div>
    <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none;">
      <div style="width:120px;height:120px;border:2px dashed rgba(233,69,96,0.2);border-radius:50%;animation:spin404 20s linear infinite;"></div>
    </div>
  </div>

  <h1 style="font-size:1.5rem;font-weight:700;color:#fafafa;margin:0 0 0.75rem;">
    ページが見つかりません
  </h1>
  <p style="color:rgba(255,255,255,0.4);font-size:0.95rem;line-height:1.7;margin:0 0 2.5rem;">
    お探しのページは移動または削除された可能性があります。<br>URLをご確認いただくか、ホームに戻ってください。
  </p>

  <!-- CTA -->
  <div style="display:flex;gap:0.75rem;flex-wrap:wrap;justify-content:center;margin-bottom:3rem;">
    <a href="/"
       style="display:inline-flex;align-items:center;gap:0.5rem;background:#e94560;color:#fff;font-size:0.9375rem;font-weight:600;padding:0.75rem 2rem;border-radius:12px;text-decoration:none;transition:background 0.15s;"
       onmouseover="this.style.background='#d63851'" onmouseout="this.style.background='#e94560'">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      ホームに戻る
    </a>
    <a href="/app"
       style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.85);font-size:0.9375rem;font-weight:500;padding:0.75rem 1.75rem;border-radius:12px;text-decoration:none;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
      アプリをダウンロード
    </a>
  </div>

  <!-- Quick links -->
  <div style="max-width:400px;margin:0 auto;">
    <p style="color:rgba(255,255,255,0.3);font-size:0.8rem;margin-bottom:0.75rem;text-transform:uppercase;letter-spacing:0.1em;font-weight:600;">人気のページ</p>
    <div style="display:flex;flex-wrap:wrap;gap:0.5rem;justify-content:center;">
      <a href="/videos" style="padding:0.4rem 0.75rem;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:8px;color:rgba(255,255,255,0.5);font-size:0.8rem;text-decoration:none;transition:border-color 0.15s;" onmouseover="this.style.borderColor='rgba(233,69,96,0.4)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'">動画</a>
      <a href="/dojos" style="padding:0.4rem 0.75rem;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:8px;color:rgba(255,255,255,0.5);font-size:0.8rem;text-decoration:none;transition:border-color 0.15s;" onmouseover="this.style.borderColor='rgba(233,69,96,0.4)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'">道場</a>
      <a href="/athletes" style="padding:0.4rem 0.75rem;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:8px;color:rgba(255,255,255,0.5);font-size:0.8rem;text-decoration:none;transition:border-color 0.15s;" onmouseover="this.style.borderColor='rgba(233,69,96,0.4)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'">選手</a>
      <a href="/tournaments" style="padding:0.4rem 0.75rem;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:8px;color:rgba(255,255,255,0.5);font-size:0.8rem;text-decoration:none;transition:border-color 0.15s;" onmouseover="this.style.borderColor='rgba(233,69,96,0.4)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'">大会</a>
      <a href="/game-plans" style="padding:0.4rem 0.75rem;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:8px;color:rgba(255,255,255,0.5);font-size:0.8rem;text-decoration:none;transition:border-color 0.15s;" onmouseover="this.style.borderColor='rgba(233,69,96,0.4)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'">ゲームプラン</a>
      <a href="/technique-map" style="padding:0.4rem 0.75rem;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:8px;color:rgba(255,255,255,0.5);font-size:0.8rem;text-decoration:none;transition:border-color 0.15s;" onmouseover="this.style.borderColor='rgba(233,69,96,0.4)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'">技術マップ</a>
      <a href="/join" style="padding:0.4rem 0.75rem;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:8px;color:rgba(255,255,255,0.5);font-size:0.8rem;text-decoration:none;transition:border-color 0.15s;" onmouseover="this.style.borderColor='rgba(233,69,96,0.4)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'">料金プラン</a>
    </div>
  </div>
</main>

<style>
@keyframes spin404 { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
</style>


<footer style="background:#0a0a0c; border-top:1px solid rgba(255,255,255,0.06); padding:3rem 0 2rem;">
  <div style="max-width:1200px; margin:0 auto; padding:0 1.5rem;">

    <!-- Top grid -->
    <div style="display:grid; grid-template-columns:1.6fr 1fr 1fr 1fr 1fr; gap:2.5rem 2rem; margin-bottom:3rem;">

      <!-- Brand -->
      <div>
        <a href="/" style="display:inline-flex; align-items:center; gap:0.5rem; text-decoration:none; margin-bottom:0.75rem;">
          <svg viewBox="0 0 90 90" width="32" height="32" style="display:block; flex-shrink:0;">
            <defs><linearGradient id="ft-g" x1="0%" y1="0%" x2="0%" y2="100%"><stop offset="0%" stop-color="#e94560"/><stop offset="100%" stop-color="#d63851"/></linearGradient></defs>
            <rect width="90" height="90" rx="18" fill="url(#ft-g)"/>
            <text x="45" y="66" text-anchor="middle" font-family="Inter,sans-serif" font-size="55" font-weight="900" fill="#fff">jf</text>
          </svg>
          <span style="font-size:1.1rem; font-weight:800; letter-spacing:0.04em; color:#f4f4f5;">JIUFLOW</span>
          <span style="display:block; font-size:0.6rem; font-weight:500; letter-spacing:0.25em; color:#D4A853; margin-top:2px;">BRAZILIAN JIU-JITSU</span>
        </a>
        <p style="font-size:0.82rem; color:rgba(255,255,255,0.35); line-height:1.6; max-width:220px; margin:0 0 1.25rem;">
          柔術を体系で学ぶ。テクニックマップ・ゲームプランビルダー・道場予約まで一元管理できるBJJ学習プラットフォーム。
        </p>
        <div style="display:flex; gap:0.6rem; flex-wrap:wrap;">
          <a href="/join" style="font-size:0.78rem; background:linear-gradient(135deg,#e94560,#d63851); color:#fff; padding:0.4rem 0.9rem; border-radius:8px; text-decoration:none; font-weight:600;">
            はじめる
          </a>
          <a href="/guide" style="font-size:0.78rem; border:1px solid rgba(255,255,255,0.15); color:rgba(255,255,255,0.6); padding:0.4rem 0.9rem; border-radius:8px; text-decoration:none;">
            使い方ガイド
          </a>
        </div>
        <div style="margin-top:1.25rem;">
          <a href="https://instagram.com/jiuFlowArt" target="_blank" rel="noopener noreferrer"
             style="font-size:0.78rem; color:rgba(255,255,255,0.35); text-decoration:none; display:inline-flex; align-items:center; gap:0.35rem;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            @jiuFlowArt
          </a>
        </div>
      </div>

      <!-- Training -->
      <div>
        <h4 style="font-size:0.72rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:rgba(255,255,255,0.3); margin:0 0 0.9rem;">トレーニング</h4>
        <nav style="display:flex; flex-direction:column; gap:0.45rem;">
          <a href="/technique-map" style="font-size:0.855rem; color:rgba(255,255,255,0.6); text-decoration:none; transition:color 0.12s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">テクニックマップ</a>
          <a href="/game-plans" style="font-size:0.855rem; color:rgba(255,255,255,0.6); text-decoration:none; transition:color 0.12s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">ゲームプラン</a>
          <a href="/roadmap" style="font-size:0.855rem; color:rgba(255,255,255,0.6); text-decoration:none; transition:color 0.12s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">ロードマップ</a>
          <a href="/instructors" style="font-size:0.855rem; color:rgba(255,255,255,0.6); text-decoration:none; transition:color 0.12s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">インストラクター</a>
        </nav>
      </div>

      <!-- Community -->
      <div>
