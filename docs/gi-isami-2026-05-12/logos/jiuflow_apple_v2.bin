<!-- #47: Cookie consent banner -->
<div id="cookie-banner" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:9997;background:rgba(18,18,20,0.97);backdrop-filter:blur(8px);border-top:1px solid rgba(255,255,255,0.1);padding:0.875rem 1.25rem;display:none;">
  <div style="max-width:900px;margin:0 auto;display:flex;align-items:center;gap:1rem;flex-wrap:wrap;">
    <p style="flex:1;min-width:200px;font-size:0.8rem;color:rgba(255,255,255,0.65);margin:0;line-height:1.5;">
      🍪 サービス改善のため匿名アクセス解析を使用しています。個人情報の販売は行いません。
      <a href="/privacy" style="color:#e94560;text-decoration:none;margin-left:0.25rem;">プライバシーポリシー</a>
    </p>
    <div style="display:flex;gap:0.5rem;flex-shrink:0;">
      <button onclick="cookieConsent('reject')" style="padding:0.5rem 1rem;background:transparent;border:1px solid rgba(255,255,255,0.2);border-radius:8px;color:rgba(255,255,255,0.5);font-size:0.8rem;cursor:pointer;font-family:inherit;">
        拒否
      </button>
      <button onclick="cookieConsent('accept')" style="padding:0.5rem 1rem;background:#e94560;border:none;border-radius:8px;color:#fff;font-size:0.8rem;font-weight:600;cursor:pointer;font-family:inherit;">
        同意する
      </button>
    </div>
  </div>
</div>
<script>
(function(){
  var KEY = 'jf_cookie_consent_v1';
  function cookieConsent(choice) {
    try { localStorage.setItem(KEY, choice); } catch(e) {}
    document.getElementById('cookie-banner').style.display = 'none';
    if (choice === 'reject') {
      // Disable analytics tracking script if user rejects
      window['__jf_analytics_disabled'] = true;
    }
  }
  window.cookieConsent = cookieConsent;
  try {
    if (!localStorage.getItem(KEY)) {
      // Show after a small delay so it doesn't flash immediately
      setTimeout(function(){ document.getElementById('cookie-banner').style.display = 'block'; }, 1500);
    }
  } catch(e) {}
})();
</script>
</body>
</html>