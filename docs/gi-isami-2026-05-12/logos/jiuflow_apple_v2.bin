<body>
<script>
// Capture referral code from URL and persist to cookie
(function(){
  try {
    var m = window.location.search.match(/[?&]ref=([a-zA-Z0-9]{4,16})/);
    if (m) {
      document.cookie = 'jiuflow_ref=' + encodeURIComponent(m[1]) + ';path=/;max-age=2592000;samesite=lax';
    }
  } catch(e) {}
})();
</script>

<!-- フィードバックモーダル -->
<div id="feedback-modal" style="display:none;position:fixed;inset:0;z-index:9998;background:rgba(0,0,0,0.8);align-items:center;justify-content:center;padding:1rem;">
  <div style="background:#111;border:1px solid #27272a;border-radius:12px;padding:1.5rem;max-width:420px;width:100%;position:relative;">
    <button onclick="document.getElementById('feedback-modal').style.display='none';" style="position:absolute;top:0.75rem;right:0.75rem;background:none;border:none;color:#71717a;font-size:1.25rem;cursor:pointer;">×</button>
    <h3 id="fb-title" style="color:#fff;font-size:1rem;margin:0 0 1rem;">フィードバック</h3>
    <div style="display:flex;gap:0.5rem;margin-bottom:1rem;" id="fb-stars">
      <span id="fb-rating-label" style="font-size:0.8rem;color:#71717a;align-self:center;">評価：</span>
      <button onclick="setRating(1)" class="fb-star" data-r="1" style="background:none;border:none;font-size:1.5rem;cursor:pointer;opacity:0.4;">⭐</button>
      <button onclick="setRating(2)" class="fb-star" data-r="2" style="background:none;border:none;font-size:1.5rem;cursor:pointer;opacity:0.4;">⭐</button>
      <button onclick="setRating(3)" class="fb-star" data-r="3" style="background:none;border:none;font-size:1.5rem;cursor:pointer;opacity:0.4;">⭐</button>
      <button onclick="setRating(4)" class="fb-star" data-r="4" style="background:none;border:none;font-size:1.5rem;cursor:pointer;opacity:0.4;">⭐</button>
      <button onclick="setRating(5)" class="fb-star" data-r="5" style="background:none;border:none;font-size:1.5rem;cursor:pointer;opacity:0.4;">⭐</button>
    </div>
    <textarea id="fb-text" placeholder="ご意見・ご要望をお聞かせください" style="width:100%;height:100px;background:#1a1a1a;border:1px solid #27272a;border-radius:8px;color:#e4e4e7;padding:0.6rem;font-size:0.85rem;resize:vertical;box-sizing:border-box;"></textarea>
    <button id="fb-submit" onclick="submitFeedback()" style="width:100%;background:#e94560;border:none;color:#fff;padding:0.65rem;border-radius:8px;font-size:0.9rem;font-weight:600;cursor:pointer;margin-top:0.75rem;">送信する</button>
    <p id="fb-msg" style="display:none;color:#22c55e;font-size:0.8rem;text-align:center;margin:0.5rem 0 0;">ありがとうございました！</p>
  </div>
</div>
<script>
// i18n for feedback widget based on URL path (en, pt, or default ja)
(function(){
  var path = location.pathname;
  var lang = /^\/en(\/|$)/.test(path) ? 'en' : (/^\/pt(\/|$)/.test(path) ? 'pt' : 'ja');
  if (lang === 'ja') return;
  var dict = {
    en: { title: 'Feedback', rating: 'Rating:', placeholder: 'Tell us what you think', submit: 'Submit', thanks: 'Thank you!' },
    pt: { title: 'Feedback', rating: 'Avaliação:', placeholder: 'Conte-nos o que você acha', submit: 'Enviar', thanks: 'Obrigado!' }
  }[lang];
  var t = document.getElementById('fb-title');
  var r = document.getElementById('fb-rating-label');
  var ta = document.getElementById('fb-text');
  var s = document.getElementById('fb-submit');
  var m = document.getElementById('fb-msg');
  if(t) t.textContent = dict.title;
  if(r) r.textContent = dict.rating;
  if(ta) ta.placeholder = dict.placeholder;
  if(s) s.textContent = dict.submit;
  if(m) m.textContent = dict.thanks;
})();
let fbRating = 0;
function setRating(n) {
  fbRating = n;
  document.querySelectorAll('.fb-star').forEach(s => {
    s.style.opacity = parseInt(s.dataset.r) <= n ? '1' : '0.3';
  });
}
async function submitFeedback() {
  const msg = document.getElementById('fb-text').value.trim();
  var path = location.pathname;
  var lang = /^\/en(\/|$)/.test(path) ? 'en' : (/^\/pt(\/|$)/.test(path) ? 'pt' : 'ja');
  if (!fbRating) {
    var msgs = {en: 'Please select a rating', pt: 'Selecione uma avaliação', ja: '評価を選んでください'};
    alert(msgs[lang]); return;
  }
  await fetch('/api/v1/feedback', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ page: location.pathname, rating: fbRating, message: msg })
  });
  document.getElementById('fb-msg').style.display = 'block';
  setTimeout(() => { document.getElementById('feedback-modal').style.display='none'; fbRating=0; document.getElementById('fb-text').value=''; document.getElementById('fb-msg').style.display='none'; document.querySelectorAll('.fb-star').forEach(s=>s.style.opacity='0.4'); }, 1500);
}
</script>

  
<!-- Navigation -->
<style>
.jf-nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: rgba(10,10,10,0.85);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.jf-nav-inner {
  max-width: 1200px; margin: 0 auto;
  padding: 0 1.25rem;
  height: 56px;
  display: flex; align-items: center; gap: 0;
}
.jf-logo {
  font-size: 1.15rem; font-weight: 300; letter-spacing: -0.03em;
  color: #f4f4f5; text-decoration: none; white-space: nowrap;
  margin-right: 2rem; flex-shrink: 0;
}
.jf-logo svg { display: block; }
/* Desktop links */
.jf-links {
  display: flex; align-items: center; gap: 0.25rem; flex: 1;
}
.jf-link {
  color: rgba(255,255,255,0.65); text-decoration: none;
  font-size: 0.875rem; font-weight: 500;
  padding: 0.35rem 0.65rem; border-radius: 6px;
  transition: color 0.15s, background 0.15s;
  white-space: nowrap;
}
.jf-link:hover { color: #f4f4f5; background: rgba(255,255,255,0.07); }
.jf-link.accent { color: #fca5a5; }
.jf-divider { width: 1px; height: 20px; background: rgba(255,255,255,0.12); margin: 0 0.75rem; flex-shrink: 0; }
/* Dropdown */
.jf-dropdown { position: relative; }
.jf-dropdown-trigger {
  color: rgba(255,255,255,0.65); text-decoration: none;
  font-size: 0.875rem; font-weight: 500;
  padding: 0.35rem 0.65rem; border-radius: 6px;
  transition: color 0.15s, background 0.15s;
  white-space: nowrap; cursor: pointer;
  background: none; border: none; font-family: inherit;
  display: flex; align-items: center; gap: 0.3rem;
}
.jf-dropdown-trigger:hover { color: #f4f4f5; background: rgba(255,255,255,0.07); }
.jf-dropdown-menu {
  display: none; position: absolute; top: calc(100% + 4px); left: 0;
  background: rgba(17,17,19,0.98); backdrop-filter: blur(16px);
  border: 1px solid rgba(255,255,255,0.1); border-radius: 10px;
  padding: 0.4rem 0; min-width: 170px;
  box-shadow: 0 12px 40px rgba(0,0,0,0.5);
}
.jf-dropdown:hover .jf-dropdown-menu { display: block; }
.jf-dropdown-menu a {
  display: block; padding: 0.5rem 1rem;
  color: rgba(255,255,255,0.65); text-decoration: none;
  font-size: 0.84rem; transition: color 0.12s, background 0.12s;
}
.jf-dropdown-menu a:hover { color: #fff; background: rgba(255,255,255,0.06); }
/* Auth section */
.jf-auth { display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0; }
.jf-btn-login {
  font-size: 0.825rem; font-weight: 600;
  background: linear-gradient(135deg,#e94560,#d63851);
  color: #fff; padding: 0.4rem 1rem; border-radius: 6px;
  text-decoration: none; transition: opacity 0.15s; white-space: nowrap;
}
.jf-btn-login:hover { opacity: 0.88; }
/* Language switcher */
.jf-lang-switcher { position: relative; margin-left: 0.5rem; }
.jf-lang-btn {
  background: none; border: 1px solid rgba(255,255,255,0.12); cursor: pointer;
  color: rgba(255,255,255,0.6); padding: 0.3rem 0.55rem; border-radius: 6px;
  font-size: 0.78rem; font-family: inherit; display: flex; align-items: center; gap: 0.3rem;
  transition: border-color 0.15s, color 0.15s;
}
.jf-lang-btn:hover { border-color: rgba(255,255,255,0.3); color: #fff; }
.jf-lang-menu {
  display: none; position: absolute; top: calc(100% + 4px); right: 0;
  background: rgba(17,17,19,0.98); backdrop-filter: blur(16px);
  border: 1px solid rgba(255,255,255,0.1); border-radius: 10px;
  padding: 0.4rem 0; min-width: 140px;
  box-shadow: 0 12px 40px rgba(0,0,0,0.5);
}
.jf-lang-switcher:hover .jf-lang-menu { display: block; }
.jf-lang-menu a {
  display: block; padding: 0.5rem 1rem;
  color: rgba(255,255,255,0.65); text-decoration: none;
  font-size: 0.84rem; transition: color 0.12s, background 0.12s;
}
.jf-lang-menu a:hover { color: #fff; background: rgba(255,255,255,0.06); }
.jf-lang-menu a.active { color: #fca5a5; }
/* Hamburger */
.jf-hamburger {
  display: none; background: none; border: none; cursor: pointer;
  color: rgba(255,255,255,0.7); padding: 0.35rem; border-radius: 6px;
  margin-left: auto;
}
.jf-hamburger:hover { color: #fff; background: rgba(255,255,255,0.08); }
/* Mobile drawer */
.jf-drawer {
  display: none; position: fixed; inset: 0; z-index: 200;
}
.jf-drawer.open { display: block; }
.jf-drawer-overlay {
  position: absolute; inset: 0;
  background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);
}
.jf-drawer-panel {
  position: absolute; top: 0; right: 0; bottom: 0; width: min(320px, 88vw);
  background: #111113; border-left: 1px solid rgba(255,255,255,0.08);
  overflow-y: auto;
  padding-top: max(1.25rem, env(safe-area-inset-top));
  padding-bottom: max(3rem, env(safe-area-inset-bottom));
  padding-right: env(safe-area-inset-right);
  display: flex; flex-direction: column;
}
.jf-drawer-close {
  position: sticky; top: max(0px, env(safe-area-inset-top));
  align-self: flex-end; margin-right: 1rem; margin-bottom: 0.5rem;
  background: rgba(17,17,19,0.9); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
  border: none; cursor: pointer; color: rgba(255,255,255,0.5);
  padding: 0.45rem; border-radius: 50%; z-index: 2; line-height: 0;
}
.jf-drawer-close:hover { color: #fff; background: rgba(255,255,255,0.1); }
.jf-drawer-section {
  padding: 0.5rem 0 0.75rem;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.jf-drawer-section:last-child { border-bottom: none; }
.jf-drawer-label {
  font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em;
  color: rgba(255,255,255,0.3); text-transform: uppercase;
  padding: 0 1.25rem; margin-bottom: 0.35rem;
}
.jf-drawer a {
  display: block; padding: 0.6rem 1.25rem;
  color: rgba(255,255,255,0.75); text-decoration: none;
  font-size: 0.95rem; transition: color 0.12s, background 0.12s;
  word-break: keep-all; overflow-wrap: anywhere; line-height: 1.4;
}
.jf-drawer a:hover { color: #fff; background: rgba(255,255,255,0.05); }
.jf-drawer a.cta { color: #fca5a5; font-weight: 600; }
.jf-drawer-logout-btn {
  display: block; padding: 0.6rem 1.25rem; width: 100%; text-align: left;
  color: rgba(255,255,255,0.45); background: none; border: none; cursor: pointer;
  font-size: 0.95rem; font-family: inherit; transition: color 0.12s, background 0.12s;
}
.jf-drawer-logout-btn:hover { color: #fff; background: rgba(255,255,255,0.05); }
.jf-drawer-lang-pills {
  display: flex; gap: 0.5rem; padding: 0.25rem 1.25rem 0.5rem;
}
.jf-lang-pill {
  flex: 1; text-align: center; padding: 0.45rem 0;
  border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;
  font-size: 0.85rem; color: rgba(255,255,255,0.55); text-decoration: none;
  transition: all 0.12s;
}
.jf-lang-pill:hover { border-color: rgba(255,255,255,0.25); color: #fff; background: rgba(255,255,255,0.05); }
.jf-lang-pill.active { background: rgba(233,69,96,0.15); border-color: rgba(233,69,96,0.5); color: #fca5a5; }
@media (max-width: 900px) {
  .jf-links { display: none; }
  .jf-auth  { display: none; }
  .jf-lang-switcher.desktop-only { display: none; }
  .jf-hamburger { display: flex; align-items: center; justify-content: center; }
}
@media (min-width: 901px) {
  .jf-lang-switcher.mobile-only { display: none; }
}
</style>

