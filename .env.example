# MU brand store — environment variables example
# Copy to .env and fill in real values for local development.
# In production (Fly.io), use `fly secrets set KEY=value -a mu-store`.

# ── Stripe (payments) ─────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── Printful (on-demand manufacturing) ────────────────────
PRINTFUL_API_KEY=REPLACE_ME

# ── Gemini (AI design generation) ─────────────────────────
GEMINI_API_KEY=REPLACE_ME

# ── Solana / NFT (optional, for MA line certificates) ─────
HELIUS_API_KEY=REPLACE_ME
SOLANA_PRIVATE_KEY=REPLACE_ME

# ── Admin token (rotate via Fly secrets) ──────────────────
ADMIN_TOKEN=replace-with-strong-random-string

# ── Public URL ────────────────────────────────────────────
BASE_URL=http://localhost:3000
